{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "barchart", "name": "Bar chart", "version": "" },
    { "type": "panel", "id": "heatmap", "name": "Heatmap", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Job and workflow performance analytics for self-hosted GitHub Actions runners.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "title": "Fleet Health",
      "type": "link",
      "url": "/d/github-runner-fleet-health",
      "tooltip": "Back to operational overview"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["github", "runner", "ci", "analytics"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(github_runner_info, instance)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "runner",
        "options": [],
        "regex": "",
        "query": {
          "query": "label_values(github_runner_info, instance)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Runner"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(github_runner_jobs_total{instance=~\"$runner\"}, repo)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "repo",
        "options": [],
        "query": {
          "query": "label_values(github_runner_jobs_total{instance=~\"$runner\"}, repo)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Repository"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\"}, workflow)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "workflow",
        "options": [],
        "query": {
          "query": "label_values(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\"}, workflow)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Workflow"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(github_runner_jobs_total{instance=~\"$runner\"}, actor)",
        "hide": 0,
        "includeAll": true,
        "multi": false,
        "name": "actor",
        "options": [],
        "query": {
          "query": "label_values(github_runner_jobs_total{instance=~\"$runner\"}, actor)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Actor"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "GitHub Runner Job Analytics",
  "uid": "github-runner-job-analytics",
  "version": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"})",
          "legendFormat": "Total Jobs"
        }
      ],
      "title": "Total Jobs",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\", status=\"succeeded\"}) / sum(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"})",
          "legendFormat": "Success Rate"
        }
      ],
      "title": "Success Rate (lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by(le)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "p50"
        }
      ],
      "title": "Median Duration (p50, lifetime)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(le)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "p95"
        }
      ],
      "title": "p95 Duration (lifetime)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 10,
      "title": "Job Volume & Success Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10, "stacking": { "mode": "none" }, "spanNulls": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "succeeded" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "cancelled" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 6 },
      "id": 11,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(status)(increase(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}[$__interval]))",
          "legendFormat": "{{status}}"
        }
      ],
      "title": "Jobs Completed by Status (cumulative)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 0.8 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 6 },
      "id": 12,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(instance)(rate(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\", status=\"succeeded\"}[$__rate_interval])) / sum by(instance)(rate(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}[$__rate_interval]))",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "Success Rate Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 20,
      "title": "Top Consumers",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "id": 21,
      "options": { "xField": "repo" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by(repo)(github_runner_jobs_total{instance=~\"$runner\"}))",
          "legendFormat": "{{repo}}",
          "instant": true
        }
      ],
      "title": "Top Repos by Job Count",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "id": 22,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by(workflow)(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\"}))",
          "legendFormat": "{{workflow}}",
          "instant": true
        }
      ],
      "title": "Top Workflows by Job Count",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "id": 23,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by(repo)(github_runner_jobs_total{instance=~\"$runner\", status=\"failed\"}))",
          "legendFormat": "{{repo}}",
          "instant": true
        }
      ],
      "title": "Top Repos by Failure Count",
      "type": "barchart"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 30,
      "title": "Duration Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "id": 31,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.50, sum by(le, workflow)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "p50 {{workflow}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.95, sum by(le, workflow)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "p95 {{workflow}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "histogram_quantile(0.99, sum by(le, workflow)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "p99 {{workflow}}"
        }
      ],
      "title": "p50 / p95 / p99 Duration by Workflow (lifetime)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "id": 32,
      "options": {
        "calculate": false,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scale": "exponential", "scheme": "Oranges" },
        "yAxis": { "unit": "s" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(le)(rate(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}[$__rate_interval]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "title": "Job Duration Heatmap",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 40,
      "title": "Runner Utilization",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 41,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg_over_time(github_runner_busy{instance=~\"$runner\"}[$__rate_interval])",
          "legendFormat": "{{instance}}"
        }
      ],
      "title": "Runner Utilization % (busy time)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "align": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95 (s)" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 42,
      "options": { "sortBy": [{ "desc": true, "displayName": "p95 (s)" }] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sort_desc(histogram_quantile(0.95, sum by(le, runner_name, workflow, job_name)(github_runner_job_duration_seconds_bucket{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"})))",
          "instant": true,
          "legendFormat": "{{runner_name}} / {{workflow}} / {{job_name}}",
          "format": "table"
        }
      ],
      "title": "Slowest Jobs — p95 Duration (lifetime)",
      "type": "table",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "runner_name": "Runner",
              "workflow": "Workflow",
              "job_name": "Job",
              "Value": "p95 (s)"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 41 },
      "id": 50,
      "title": "Actor Analysis",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 42 },
      "id": 51,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by(actor)(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\"}))",
          "legendFormat": "{{actor}}",
          "instant": true
        }
      ],
      "title": "Top Actors by Job Count",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 42 },
      "id": 52,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "topk(10, sum by(actor) (increase(github_runner_job_duration_seconds_sum{instance=\"$runner\"}[$__range])))",
          "legendFormat": "{{actor}}",
          "instant": true
        }
      ],
      "title": "Runner-Seconds by Actor",
      "type": "barchart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "stacking": { "mode": "normal" } } }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 42 },
      "id": 53,
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by(actor) (github_runner_current_job_info{instance=~\"$runner\", actor=~\"$actor\"})",
          "legendFormat": "{{actor}}"
        }
      ],
      "title": "Busy Over Time by Actor",
      "type": "timeseries"
    }
  ]
}
