        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(github_runner_jobs_total{instance=~\"$runner\", repo=~\"$repo\", workflow=~\"$workflow\", actor=~\"$actor\"})",
          "legendFormat": "Total Jobs",
          "refId": "A",
          "instant": true
        }
      ],
      "title": "Total Jobs",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
